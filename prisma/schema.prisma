generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  provider  String   @default("dev") // "dev" | "google"
  profile   Json?    // Stores answers to thoughtful "about me" questions
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entries   JournalEntry[]

  @@map("users")
}

model JournalEntry {
  id          String   @id @default(cuid())
  text        String
  textPreview String?  // First ~150 chars for list views, avoids sending full text
  mood        Int      @default(2) // 0-4: Heavy, Low, Okay, Good, Radiant
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  song        String?
  entryType   String   @default("normal") // normal, letter, unsent_letter, ephemeral
  unlockDate  DateTime?
  isSealed    Boolean  @default(false)
  expiresAt   DateTime?
  tags        String[] @default([])
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Letter-specific fields (for letters to friends)
  recipientEmail  String?   // Friend's email address
  recipientName   String?   // Friend's name for personalization
  senderName      String?   // How sender wants to be identified
  letterLocation  String?   // Where the letter was written from (e.g., "Himachal Pradesh")
  isDelivered     Boolean   @default(false)  // Has the letter been sent/delivered
  deliveredAt     DateTime? // When the letter was delivered
  isViewed        Boolean   @default(false)  // Has the user viewed this letter after it arrived

  doodles     Doodle[]

  // Indexes for scalable queries
  @@index([userId, createdAt(sort: Desc)]) // Timeline queries
  @@index([userId, mood])                   // Mood filtering
  @@index([userId, createdAt, mood])        // Combined filters
  @@index([unlockDate, isDelivered])        // For cron job to find due letters
  @@map("journal_entries")
}

model Doodle {
  id              String       @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  strokes         Json         // Array of stroke data
  positionInEntry Int          @default(0)
  createdAt       DateTime     @default(now())

  @@map("doodles")
}

model BookQuote {
  id          String   @id @default(cuid())
  quoteText   String
  bookTitle   String
  author      String?
  mood        Int?
  createdAt   DateTime @default(now())

  @@map("book_quotes")
}

model Whisper {
  id       String @id @default(cuid())
  text     String
  category String @default("generic") // generic, mood-specific, pattern-based

  @@map("whispers")
}
