public/workbox-*.js
public/sw.js.map
public/workbox-*.js.map
public/swe-worker-*.js
public/swe-worker-*.js.map

# worktrees
.worktrees/

# brainstorming session mockups
.superpowers/

# Playwright MCP scratch artifacts (page snapshots, console logs)
.playwright-mcp/
